{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/collect-analytics",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/send-lead-sms",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/auto-brand-report",
      "schedule": "*/5 * * * *"
    }
  ]
}

# Google Analytics 4 설정
GA4_PROPERTY_ID=514776969

# Google Search Console 설정
SEARCH_CONSOLE_SITE_URL=https://polarad.co.kr

# 서비스 계정 (Google Cloud Console에서 발급)
# GA4와 Search Console 모두 동일한 서비스 계정 사용
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# D1/R2 Proxy Worker
D1_PROXY_URL=https://polarad-d1-proxy.<account>.workers.dev
D1_PROXY_TOKEN=replace-with-internal-token

# 채팅 링크/알림
NEXT_PUBLIC_CHAT_BASE_URL=https://chat.polarad.co.kr
NEXT_PUBLIC_APP_URL=https://dashboard.polarad.co.kr
CHAT_AUTH_SECRET=replace-with-long-random-secret
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
CHAT_TELEGRAM_BOT_TOKEN=replace-with-customer-chat-bot-token
CHAT_TELEGRAM_CHAT_ID=replace-with-customer-chat-group-id
CHAT_TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret

# 고객 채팅 이메일 OTP/초대
SMTP_HOST=smtp.worksmobile.com
SMTP_PORT=587
SMTP_USER=mkt@polarad.co.kr
SMTP_PASS=replace-with-smtp-password
SMTP_FROM_NAME=폴라애드
SEND_EMAIL_SECRET=replace-with-internal-send-email-secret
MAIL_ASSET_BASE_URL=https://dashboard.polarad.co.kr
# MAIL_PROFILE_IMAGE_URL=https://dashboard.polarad.co.kr/images/mail/polarad-profile.png

# 네이버웍스 수신함 조회
IMAP_HOST=imap.worksmobile.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=mkt@polarad.co.kr
IMAP_PASS=replace-with-external-app-password

# 고객 채팅 문자 초대 (NCP SENS)
NCP_SERVICE_ID=replace-with-service-id
NCP_ACCESS_KEY=replace-with-access-key
NCP_SECRET_KEY=replace-with-secret-key
NCP_SENDER_PHONE=replace-with-sender-phone

# Schedule management
# 외부 연동 API 토큰: Authorization: Bearer ${SCHEDULE_API_TOKEN}
SCHEDULE_API_TOKEN=
# Google Calendar 동기화. 미설정 시 D1 저장만 수행합니다.
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_TIMEZONE=Asia/Seoul
GOOGLE_CALENDAR_OFFSET=+09:00
# 일정 알림 전용 텔레그램. 미설정 시 TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID 사용.
SCHEDULE_TELEGRAM_BOT_TOKEN=
SCHEDULE_TELEGRAM_CHAT_ID=
